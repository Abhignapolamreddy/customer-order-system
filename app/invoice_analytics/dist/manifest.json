{
	"_version": "1.84.0",
	"sap.app": {
		"id": "project1",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"supportedLocales": [
				""
			]
		},
		"applicationVersion": {
			"version": "0.0.1"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"resources": "resources.json",
		"sourceTemplate": {
			"id": "@sap/generator-fiori:alp",
			"version": "1.24.0",
			"toolsId": "02526c16-cdb0-4a3e-b7de-c7ecd7a75ffc"
		},
		"dataSources": {
			"mainService": {
				"uri": "/odata/v4/invoice/",
				"type": "OData",
				"settings": {
					"annotations": [],
					"odataVersion": "4.01"
				}
			}
		},
		"crossNavigation": {
			"inbounds": {
				"sales_portal-display": {
					"semanticObject": "sales_portal",
					"action": "display",
					"signature": {
						"parameters": {},
						"additionalParameters": "allowed"
					}
				}
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"flexEnabled": true,
		"dependencies": {
			"minUI5Version": "1.148.0",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.fe.templates": {}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "project1.i18n.i18n",
					"supportedLocales": [
						""
					]
				}
			},
			"": {
				"dataSource": "mainService",
				"preload": true,
				"settings": {
					"operationMode": "Server",
					"autoExpandSelect": true,
					"earlyRequests": true
				}
			},
			"@i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"uri": "i18n/i18n.properties",
				"settings": {
					"supportedLocales": [
						""
					]
				}
			}
		},
		"resources": {
			"css": []
		},
		"routing": {
			"config": {},
			"routes": [
				{
					"pattern": ":?query:",
					"name": "InvoiceAnalyticsList",
					"target": "InvoiceAnalyticsList"
				},
				{
					"pattern": "InvoiceAnalytics({key}):?query:",
					"name": "InvoiceAnalyticsObjectPage",
					"target": "InvoiceAnalyticsObjectPage"
				}
			],
			"targets": {
				"InvoiceAnalyticsList": {
					"type": "Component",
					"id": "InvoiceAnalyticsList",
					"name": "sap.fe.templates.ListReport",
					"options": {
						"settings": {
							"contextPath": "/InvoiceAnalytics",
							"variantManagement": "Page",
							"navigation": {
								"InvoiceAnalytics": {
									"detail": {
										"route": "InvoiceAnalyticsObjectPage"
									}
								}
							},
							"controlConfiguration": {
								"@com.sap.vocabularies.UI.v1.LineItem": {
									"tableSettings": {
										"type": "AnalyticalTable",
										"selectionMode": "Multi"
									}
								}
							},
							"views": {
								"paths": [
									{
										"primary": [
											{
												"annotationPath": "com.sap.vocabularies.UI.v1.PresentationVariant#Default"
											}
										],
										"secondary": [
											{
												"annotationPath": "com.sap.vocabularies.UI.v1.LineItem"
											}
										],
										"defaultPath": "both"
									}
								]
							}
						}
					}
				},
				"InvoiceAnalyticsObjectPage": {
					"type": "Component",
					"id": "InvoiceAnalyticsObjectPage",
					"name": "sap.fe.templates.ObjectPage",
					"options": {
						"settings": {
							"editableHeaderContent": false,
							"contextPath": "/InvoiceAnalytics"
						}
					}
				}
			}
		},
		"flexBundle": false
	},
	"sap.fiori": {
		"registrationIds": [],
		"archeType": "analytical"
	},
	"sap.fe": {
		"app": {
			"enableLazyLoading": true
		}
	},
	"sap.cloud": {
		"public": true,
		"service": "customerordersystem.service"
	}
}